<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 圆角矩形 -->
    <corners android:radius="12dp" />

    <!-- 边框颜色和宽度 -->
    <stroke
        android:width="2dp"
        android:color="#FFD700" />

    <!-- 填充颜色（浅黄色背景） -->
    <solid android:color="#FFFDE7" />

    <!-- 边距（可选，让内容不贴边） -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>